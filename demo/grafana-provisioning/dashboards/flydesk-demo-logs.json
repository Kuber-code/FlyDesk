{
  "uid": "flydesk-demo-logs",
  "title": "FlyDesk — Logs (Loki)",
  "tags": ["flydesk", "demo", "logs"],
  "editable": true,
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({project=\"demo\"}, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "stat", "title": "Error lines (selected range)", "id": 1,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 } ] } } },
      "targets": [ { "refId": "A", "expr": "sum(count_over_time({project=\"demo\"} |~ `(?i)error|exception|traceback` [$__range]))", "instant": true } ]
    },
    {
      "type": "stat", "title": "Total log lines (selected range)", "id": 2,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "targets": [ { "refId": "A", "expr": "sum(count_over_time({project=\"demo\"} [$__range]))", "instant": true } ]
    },
    {
      "type": "timeseries", "title": "Log volume by service (lines/min)", "id": 3,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "targets": [ { "refId": "A", "expr": "sum by (service) (count_over_time({project=\"demo\", service=~\"$service\"} [1m]))", "legendFormat": "{{service}}" } ]
    },

    { "type": "row", "title": "Streams", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 } },
    {
      "type": "logs", "title": "Live logs", "id": 4,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 7 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [ { "refId": "A", "expr": "{project=\"demo\", service=~\"$service\"}" } ]
    },
    {
      "type": "logs", "title": "Errors only", "id": 5,
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [ { "refId": "A", "expr": "{project=\"demo\"} |~ `(?i)error|exception|traceback`" } ]
    }
  ]
}
