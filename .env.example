# Copy to .env and fill in. .env is git-ignored.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- MongoDB (domain documents: orders/itineraries) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flydesk

# --- Redis (offer cache + idempotency reservation) ---
REDIS_URL=redis://localhost:6379/0
OFFER_CACHE_TTL=60

# --- Kafka (outbox relay + consumers) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Duffel (live integration target; Amadeus Self-Service retires mid-2026) ---
# Get a free sandbox token at https://app.duffel.com  -> Developer -> Access tokens.
# Test tokens are prefixed with `duffel_test_`.
DUFFEL_API_TOKEN=duffel_test_xxxxxxxxxxxxxxxxxxxxxx
DUFFEL_API_URL=https://api.duffel.com
DUFFEL_API_VERSION=v2

# Provider used by the search/booking endpoints (duffel | amadeus)
FLYDESK_PROVIDER=duffel
