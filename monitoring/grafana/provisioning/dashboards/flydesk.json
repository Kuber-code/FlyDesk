{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "FlyDesk",
  "tags": ["flydesk"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s) by view",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flydesk_http_requests_total[1m])) by (view)",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(flydesk_http_request_duration_seconds_bucket[5m])) by (le, view))",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bookings created",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flydesk_bookings_total"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tickets issued",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flydesk_tickets_issued_total"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Provider degradations (rate/5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flydesk_provider_degraded_total[5m])) by (provider)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kafka consumer lag (messages behind)",
      "description": "How many messages each consumer group is behind the log head. Read straight from Redpanda's /public_metrics; a healthy stream sits near 0, a stuck or slow consumer climbs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (redpanda_group, redpanda_topic) (redpanda_kafka_consumer_group_lag_sum)",
          "legendFormat": "{{redpanda_group}} / {{redpanda_topic}}"
        }
      ]
    }
  ]
}
